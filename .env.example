# Copy to `.env` for local secrets. This repo does not auto-load `.env` for `npm run verify`;
# export vars in your shell or use direnv / dotenv-cli when tooling needs them.

# --- UPSked ingest HTTP (partner Bearer: upsked_ingest_v1_…) ---
# Web origin, no trailing slash.
# UPSKED_INGEST_BASE_URL=https://upsked.com
# UPSKED_INGEST_BASE_URL=http://localhost:3000

# Mint in UPSked (Settings → Integrations → Ingest) or SQL + app pepper (main repo docs).
# Production https://upsked.com: token row must use environment=production or ingest returns 403.
# UPSKED_INGEST_TOKEN=

# --- Live ingest / monorepo `simulate-partner-ingest` parity ---
# INGEST_LIVE=1
# INGEST_SIM_BUNDLE_DIR=./fixtures/upb/sample-release
# UPB_CATALOG_DATA_DIR=
# INGEST_SIM_SEMESTER_ID=upb-2026-1
# INGEST_SIM_CATALOG_SOURCE_KEY=upb-main-catalog
# INGEST_SIM_UNIVERSITY_ID=upb
# INGEST_SIM_RELEASE_ID=
# INGEST_SIM_CONNECTOR_ID=
# INGEST_SIM_CONNECTOR_VERSION=

# --- UPB connector: `connectors/upb` → `npm run amis:clean` (clean-for-upsked.cjs) ---
# UPB_SEMESTER_ID=upb-2026-1

# --- Other schools’ extractors (examples; not used by core verifier CLI) ---
# AMIS_SESSION=
# AMIS_BASE_URL=
