# Copy to `.env` and fill in. Used when pushing a verifier-clean bundle to UPSked via the
# main app ingest API (or tooling that reads these names). `npm run verify` needs no secrets.

# --- UPSked ingest HTTP (partner Bearer: upsked_ingest_v1_…) ---
# Web origin, no trailing slash (local dev or production).
# UPSCHED_INGEST_BASE_URL=http://localhost:3000
# Alias also accepted by @upsked/ingest-client:
# UPSKED_INGEST_BASE_URL=

# Plaintext token (minted in UPSked Settings → Integrations or SQL insert aligned with app pepper).
# UPSCHED_INGEST_TOKEN=

# --- Optional: live pipeline smoke (mirrors main repo simulate-partner-ingest) ---
# INGEST_LIVE=1
# INGEST_SIM_BUNDLE_DIR=./fixtures/upb/sample-release
# INGEST_SIM_SEMESTER_ID=upb-2026-1
# INGEST_SIM_CATALOG_SOURCE_KEY=upb-main-catalog
# INGEST_SIM_UNIVERSITY_ID=upb
# INGEST_SIM_RELEASE_ID=
# INGEST_SIM_CONNECTOR_ID=
# INGEST_SIM_CONNECTOR_VERSION=

# --- Connector extractors (only if your connector reads env; not used by verifier CLI) ---
# Example placeholders — rename to match your school’s scripts under connectors/.
# AMIS_SESSION=
# AMIS_BASE_URL=
